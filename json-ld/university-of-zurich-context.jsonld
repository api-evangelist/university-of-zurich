      "@id": "uzh:identityProvider",
      "@type": "@id"
    },
    "issuer": {
      "@id": "eduid:issuer",
      "@type": "@id"
    },
    "Person": "schema:Person",
    "sub": "schema:identifier",
    "givenName": "schema:givenName",
    "given_name": "schema:givenName",
    "familyName": "schema:familyName",
    "family_name": "schema:familyName",
    "email": "schema:email",
    "email_verified": "eduid:emailVerified",
    "locale": "eduid:locale",
    "swissEduID": "eduid:swissEduID",
